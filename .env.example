PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168
ENV=development

# Database and Redis connection strings are automatically derived from the
# component variables below. You do not need to set DATABASE_URL or REDIS_ADDR.

# Database
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=admission
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Alibaba Cloud SMS
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# SMS verification
SMS_CODE_TTL_MINUTES=5
SMS_SEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10
SMS_MAX_VERIFY_ATTEMPTS=5

# Candidate profile encryption (AES-256-GCM + HMAC-SHA256, HKDF-derived from one master key)
# Generate: openssl rand -hex 32
CANDIDATE_IDCARD_MASTER_KEY=d14f89b3056df76a4c2c55306cea4ffe8dcb0f8c364ed51ed3864763fb80a644
# Binding code Redis TTL (hours)
CANDIDATE_BIND_CODE_TTL_HOURS=24
