PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168
ENV=development

# Database and Redis connection strings are automatically derived from the
# component variables below. You do not need to set DATABASE_URL or REDIS_ADDR.

# Database
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=admission
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Alibaba Cloud SMS
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# SMS verification
SMS_CODE_TTL_MINUTES=5
SMS_SEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10
SMS_MAX_VERIFY_ATTEMPTS=5
