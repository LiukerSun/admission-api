PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168
ENV=development

# Database and Redis connection strings are automatically derived from the
# component variables below. You do not need to set DATABASE_URL or REDIS_ADDR.

# Database
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=admission
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Alibaba Cloud SMS
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=哈尔滨柏溪教育科技
ALIYUN_SMS_TEMPLATE_CODE=SMS_506115262
ALIYUN_SMS_TEMPLATE_PARAM_FORMAT=json

# SMS verification
SMS_CODE_TTL_MINUTES=5
SMS_SEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10
SMS_MAX_VERIFY_ATTEMPTS=5

# LLM
# Provider: openai (OpenAI-compatible) or anthropic
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Example (DeepSeek OpenAI-compatible):
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxx

# Example (DeepSeek Anthropic protocol):
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.deepseek.com/anthropic
# LLM_MODEL=deepseek-v4-pro
# LLM_API_KEY=sk-xxx

# render_card outbound link whitelist (comma-separated)
CARD_LINK_WHITELIST=

VOLUNTEER_PLANS_FILE_PATH=../admission-frontend/plans.json

# Alipay payment.
#
# 私钥 + 三套证书有两种使用模式：
#
# (1) 生产环境（推荐）—— 走 Docker Compose secrets
#     证书文件放在宿主机 /etc/admission-api/certs/，docker-compose.prod.yml
#     已经把它们挂到容器内的 /run/secrets/。.env 里完全不写证书内容，本文件
#     和 git 仓库都看不到任何明文。具体见 docker-compose.prod.yml 的 secrets 段。
#     这种模式下 ALIPAY_*_PATH 已经在 docker-compose.prod.yml 的 environment
#     块里硬编码了，本 .env 中下面的 ALIPAY_*_PATH / ALIPAY_*_CERT 全留空。
#
# (2) 开发环境（go run / godotenv）—— 字符串内容直接写到 .env
#     字符串值支持三种格式：
#       - 原始 PEM 多行（godotenv 接受双引号包裹的多行字符串）
#       - 单行内嵌 \n 字面量
#       - base64(PEM) 一整行
#
# 优先级：内容字段 > 路径字段。
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_APP_PRIVATE_KEY_PATH=
ALIPAY_APP_PUBLIC_CERT=
ALIPAY_APP_PUBLIC_CERT_PATH=
ALIPAY_ALIPAY_PUBLIC_CERT=
ALIPAY_ALIPAY_PUBLIC_CERT_PATH=
ALIPAY_ALIPAY_ROOT_CERT=
ALIPAY_ALIPAY_ROOT_CERT_PATH=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_SANDBOX=true

# AES encryption keys (from Alipay Open Platform - Interface Encryption Settings)
# Leave empty if not using encrypted communication
ALIPAY_ENCRYPT_KEY=
ALIPAY_DECRYPT_KEY=
